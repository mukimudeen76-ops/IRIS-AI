    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qrcode.react": "^4.2.0",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "react-tooltip": "^6.0.7",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
